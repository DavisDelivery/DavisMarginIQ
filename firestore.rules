rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All MarginIQ data requires authentication
    function isAuth() { return request.auth != null; }
    match /marginiq_config/{docId} { allow read, write: if isAuth(); }
    match /payroll_runs/{runId} { allow read: if isAuth(); allow write: if false; }
    match /reports_1099/{docId} { allow read: if isAuth(); allow write: if false; }
    match /uline_audits/{date} { allow read, write: if isAuth(); }
    match /nuvizz_stops/{stopId} { allow read, write: if isAuth(); }
    match /nuvizz_manifests/{date} { allow read, write: if isAuth(); match /stops/{stopId} { allow read, write: if isAuth(); } }
    match /b600_timeclock/{docId} { allow read, write: if isAuth(); }
    match /qbo_imports/{docId} { allow read, write: if isAuth(); }
    match /drivers/{driverId} { allow read, write: if isAuth(); }
    match /employees/{employeeId} { allow read, write: if isAuth(); }
    match /costs/{date} { allow read, write: if isAuth(); }
    match /margin_summary/{weekOf} { allow read: if isAuth(); allow write: if false; }
  }
}
