rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Payroll runs — written by GitHub Actions (service account), read-only from web ──
    match /payroll_runs/{runId} {
      allow read: if true;
      allow write: if false; // service account writes via Admin SDK only
    }

    // ── 1099 reports ──
    match /reports_1099/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Uline audits — read-only from web, written by scraper ──
    match /uline_audits/{date} {
      allow read: if true;
      allow write: if false;
    }

    // ── NuVizz manifests ──
    match /nuvizz_manifests/{date} {
      allow read: if true;
      allow write: if false;
      match /stops/{stopId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── Driver roster — read/write from web (internal tool, no auth yet) ──
    match /drivers/{driverId} {
      allow read, write: if true;
    }

    // ── Daily costs — read/write from web ──
    match /costs/{date} {
      allow read, write: if true;
    }

    // ── Weekly margin summaries — written by scraper, read from web ──
    match /margin_summary/{weekOf} {
      allow read: if true;
      allow write: if false;
    }

  }
}
