rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /payroll_runs/{runId} {
      allow read: if true;
      allow write: if false;
    }

    match /reports_1099/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Legacy uline_audits (v1.x)
    match /uline_audits/{date} {
      allow read, write: if true;
    }

    // v2.1 monthly (legacy, still readable)
    match /uline_monthly/{month} {
      allow read, write: if true;
    }

    // v2.2 weekly rollups (billed revenue)
    match /uline_weekly/{weekId} {
      allow read, write: if true;
    }

    // v2.2 reconciliation by week (billed vs paid)
    match /recon_weekly/{weekId} {
      allow read, write: if true;
    }

    // Unpaid stops queue
    match /unpaid_stops/{proKey} {
      allow read, write: if true;
    }

    // DDIS payment file metadata
    match /ddis_files/{fileId} {
      allow read, write: if true;
    }

    // DDIS per-PRO payment rows (one doc per PRO+bill_date+check). Used by
    // audit rebuild for billed-vs-paid variance matching. Pre-v2.42.13
    // these were written client-side via the authenticated Firebase JS SDK,
    // so the missing collection rule was never noticed. v2.42.13's BG worker
    // writes via the REST batchWrite endpoint with the public web key, which
    // requires an explicit allow-rule.
    match /ddis_payments/{paymentId} {
      allow read, write: if true;
    }

    // DDIS dispatcher staging area (v2.42.13 chunked-payload fix). Holds
    // gzipped+base64 chunks between dispatcher write and BG read; cleaned
    // up by the BG after successful processing. Effectively an internal
    // queue, but needs read/write for the BG to load and delete chunks.
    match /ddis_ingest_payloads/{chunkId} {
      allow read, write: if true;
    }

    // File upload log
    match /file_log/{fileId} {
      allow read, write: if true;
    }

    // ─── v2.3 Multi-source collections ───
    // NuVizz stop-level cross-reference (pro → driver + 1099 pay base)
    match /nuvizz_stops/{proKey} {
      allow read, write: if true;
    }

    // NuVizz weekly driver rollups
    match /nuvizz_weekly/{weekId} {
      allow read, write: if true;
    }

    // Time clock (SENTINEL / B600) daily entries
    match /timeclock_daily/{entryId} {
      allow read, write: if true;
    }

    // Time clock weekly rollups by employee
    match /timeclock_weekly/{weekId} {
      allow read, write: if true;
    }

    // Payroll (CyberPay) weekly register by employee
    match /payroll_weekly/{weekId} {
      allow read, write: if true;
    }

    // QuickBooks historical exports (P&L, TB, GL)
    match /qbo_history/{periodId} {
      allow read, write: if true;
    }

    // Unified source file archive (every upload across all sources)
    match /source_files/{fileId} {
      allow read, write: if true;
    }

    // Driver W2/1099 classifications (manual + fleet-mgmt sourced)
    match /driver_classifications/{driverKey} {
      allow read, write: if true;
    }

    // ─── AuditIQ (v2.5) ───
    // Per-stop audit records: billed vs paid, category, dispute status
    match /audit_items/{proKey} {
      allow read, write: if true;
    }

    // Customer AP contacts (billing email, contact name, SLA, portal URL)
    match /customer_ap_contacts/{customerKey} {
      allow read, write: if true;
    }

    // Dispute submissions and outcomes
    match /disputes/{disputeId} {
      allow read, write: if true;
    }

    // ─── Fuel tracking (v2.6) ───
    // Invoice-level summary: one doc per invoice (vendor + period + totals + true rate)
    match /fuel_invoices/{invoiceId} {
      allow read, write: if true;
    }

    // Per-truck-per-invoice fuel line items
    match /fuel_by_truck/{lineId} {
      allow read, write: if true;
    }

    // Weekly vendor rollups (auto-computed on ingest)
    match /fuel_weekly/{weekId} {
      allow read, write: if true;
    }

    match /nuvizz_manifests/{date} {
      allow read: if true;
      allow write: if false;
      match /stops/{stopId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /drivers/{driverId} {
      allow read, write: if true;
    }

    match /costs/{date} {
      allow read, write: if true;
    }

    match /marginiq_config/{docId} {
      allow read, write: if true;
    }

    match /margin_summary/{weekOf} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Data Hub master collections (v2.41) ───
    // Canonical employee roster — single source of truth across all Davis apps.
    // SENTINEL, Fleet Mgmt, Dispatch, MarginIQ all read from here. Writes go
    // through DataHubTab.jsx UI or ingestion functions.
    match /employees/{employeeId} {
      allow read, write: if true;
    }

    // Canonical vehicle roster (trucks, trailers, forklifts).
    match /vehicles/{vehicleId} {
      allow read, write: if true;
    }

    // Canonical customer master. Replaces customer_ap_contacts long-term.
    match /customers/{customerId} {
      allow read, write: if true;
    }

  }
}
